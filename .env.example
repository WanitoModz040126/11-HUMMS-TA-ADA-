# Create a free Redis database from the Vercel Marketplace (Upstash integration)
# Vercel Dashboard -> Storage -> Create Database -> Upstash (Redis)
# Vercel will set these two variables for you automatically when you connect
# the database to this project. For local development, run:
#   vercel env pull .env.local
# and it will fill these in for you.

KV_REST_API_URL=
KV_REST_API_TOKEN=
